{
  "nix.enableLanguageServer": true,
  "nix.serverPath": "nixd",
  "nix.serverSettings": {
    "nixd": {
      "formatting": {
        "command": [
          "nixfmt"
        ]
      },
      "options": {
        "nixos": {
          "expr": "(builtins.getFlake \"./flake.nix\").nixosConfigurations.<name>.options"
        }
      }
    }
  }
}
